FROM /home/roygi/call-analytics-ai-platform_aws/call-analytics/ollama/dictalm2.0-instruct.Q4_K_M.gguf

# Template for DictaLM 2.0-Instruct format (official format from HuggingFace)
# Note: DictaLM does NOT support system prompts, only user/assistant format
# IMPORTANT: Ollama adds BOS token automatically - don't include <s>
TEMPLATE """{{ if .Prompt }}[INST] {{ .Prompt }} [/INST]{{ end }}"""

# Optimized parameters for Hebrew call center analysis
PARAMETER temperature 0.5
PARAMETER top_k 20
PARAMETER top_p 0.7
PARAMETER repeat_penalty 1.1
PARAMETER num_ctx 4096
PARAMETER num_predict 3000
PARAMETER frequency_penalty 0.1
PARAMETER presence_penalty 0.1
PARAMETER num_gpu 99

# Stop tokens for DictaLM format
PARAMETER stop </s>
PARAMETER stop [INST]
PARAMETER stop [/INST]

# Note: System prompts are NOT supported by DictaLM 2.0-Instruct
# All instructions must be included in the user prompt itself